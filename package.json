{
  "name": "promptflow",
  "version": "1.0.0",
  "description": "Professional offline-first prompt management tool.",
  "main": "dist/main/index.js",
  "scripts": {
    "dev:renderer": "vite",
    "build:renderer": "tsc -p tsconfig.renderer.json && vite build",
    "compile:main": "tsc -p tsconfig.main.json",
    "watch:main": "tsc -p tsconfig.main.json -w",
    "dev": "concurrently -k \"npm run dev:renderer\" \"npm run watch:main\" \"wait-on http://127.0.0.1:5173 && cross-env NODE_ENV=development electron .\"",
    "build": "npm run build:renderer && npm run compile:main",
    "postinstall": "electron-builder install-app-deps",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "package": "npm run build && electron-builder"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/better-sqlite3": "^7.6.10",
    "@types/node": "^20.12.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "electron-rebuild": "^3.2.9",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.4.5",
    "vite": "^5.2.11",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.promptflow.app",
    "productName": "PromptFlow",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "asar": true,
    "win": {
      "target": "nsis"
    }
  }
}
